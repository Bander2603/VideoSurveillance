{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure VideoSurveillance (msvc-debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "msvc-debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Build VideoSurveillance (msvc-debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "msvc-debug-build"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": [
                "Configure VideoSurveillance (msvc-debug)"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$msCompile"
            ]
        }
    ]
}
