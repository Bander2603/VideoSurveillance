{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run VideoSurveillance (x64-debug)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/out/build/x64-debug/VideoSurveillance.exe",
            "cwd": "${workspaceFolder}/out/build/x64-debug",
            "environment": [
                {
                    "name": "PATH",
                    "value": "${env:QT_ROOT}/bin;${env:PATH}"
                }
            ],
            "externalConsole": false,
            "stopAtEntry": false
        }
    ]
}
